{
  "$id": "https://fundexecs.dev/schemas/character-config.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "properties": {
    "accessories": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "characterId": {
      "minLength": 1,
      "type": "string"
    },
    "createdAt": {
      "type": "string"
    },
    "direction": {
      "enum": [ "down", "left", "right", "up" ]
    },
    "displayName": {
      "minLength": 1,
      "type": "string"
    },
    "expression": {
      "enum": [ "neutral", "smile", "focused", "talk" ]
    },
    "face": {
      "minLength": 1,
      "type": "string"
    },
    "facialHair": {
      "type": [ "string", "null" ]
    },
    "facialHairColor": {
      "minLength": 1,
      "type": "string"
    },
    "fitGroup": {
      "enum": [ "masculine-fit", "feminine-fit", "universal" ]
    },
    "hair": {
      "type": [ "string", "null" ]
    },
    "hairColor": {
      "minLength": 1,
      "type": "string"
    },
    "headCovering": {
      "type": [ "string", "null" ]
    },
    "manifestVersion": {
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
      "type": "string"
    },
    "materialOverrides": {
      "patternProperties": {
        "^.+$": {
          "properties": {
            "material": {
              "type": "string"
            },
            "palette": {
              "type": "string"
            }
          },
          "type": "object"
        }
      },
      "type": "object"
    },
    "modifiedAt": {
      "type": "string"
    },
    "outfitColorway": {
      "minLength": 1,
      "type": "string"
    },
    "outfitSystem": {
      "minLength": 1,
      "type": "string"
    },
    "seed": {
      "minimum": 0,
      "type": "integer"
    },
    "skinPalette": {
      "minLength": 1,
      "type": "string"
    },
    "state": {
      "enum": [ "idle", "walk", "talk", "approve" ]
    }
  },
  "required": [ "characterId", "displayName", "manifestVersion", "fitGroup", "skinPalette", "face", "expression", "hairColor", "facialHairColor", "outfitSystem", "outfitColorway", "accessories", "materialOverrides", "direction", "state", "createdAt", "modifiedAt" ],
  "title": "FundExecs Character Configuration",
  "type": "object"
}