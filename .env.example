# Supabase — copy this file to .env.local and fill in real values.
# Find these in your Supabase project: Settings → API.

# Safe to expose to the browser (used by the client + SSR clients).
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only. NEVER expose this to the browser or commit it.
# Used for privileged server actions / admin tasks.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
