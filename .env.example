# Supabase — copy this file to .env.local and fill in real values.
# Find these in your Supabase project: Settings → API.

# Safe to expose to the browser (used by the client + SSR clients).
# This must be the SAME host the app actually talks to. In production this is the
# Supabase CUSTOM DOMAIN https://auth.fundexecs.com (the bare https://<ref>.supabase.co
# URL also works, but the deployed app uses the custom domain). Google's OAuth
# callback is <this host>/auth/v1/callback, so the Authorized redirect URI in
# Google Cloud MUST match whatever is set here.
NEXT_PUBLIC_SUPABASE_URL=https://auth.fundexecs.com
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Canonical public origin of the app — auth (OAuth + email) always redirects
# back here regardless of which host initiated the flow. No trailing slash.
# Use the canonical production host www.fundexecs.com (the apex fundexecs.com
# 308-redirects to it); keeping auth on one host avoids losing the PKCE cookie
# across the apex→www redirect.
NEXT_PUBLIC_SITE_URL=https://www.fundexecs.com

# Server-only. NEVER expose this to the browser or commit it.
# Used for privileged server actions / admin tasks (ingestion writes via
# lib/supabase/admin.ts bypass RLS, so this key must stay server-side).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Integrations (relationship intelligence / warm connections) ---
# Google (Gmail + Calendar) sync uses the OAuth provider_token from the user's
# Supabase session. Enable the Google provider in Supabase Auth and request the
# scopes below so POST /api/integrations/{gmail|google_calendar}/sync works:
#   https://www.googleapis.com/auth/calendar.readonly
#   https://www.googleapis.com/auth/gmail.metadata
# Other providers (Calendly, Slack, Apollo, Outlook) plug into the same
# ingestion pipeline once their OAuth + adapter are added.
#
# These providers do NOT use the Google session token. Each has its own OAuth
# app / API key; per-provider OAuth requirements are documented in the adapter
# file headers under lib/integrations/providers/. The sync route resolves their
# access token at runtime from the connection row's
# `integration_connections.metadata.access_token` (read via the admin client) —
# no extra env vars are required here. To connect one, store its token on that
# row's metadata; the route returns "Connect {provider} first (no stored token)"
# until it is present.
#   - Calendly:  OAuth app, read scheduled events/invitees
#   - Slack:     OAuth app, scopes im:history, im:read, users:read, users:read.email
#   - Apollo:    API key (sent as X-Api-Key)
#   - Outlook:   Azure AD app, Microsoft Graph Calendars.Read scope

# --- AI Copilot ("Earn") ---
# Claude powers Earn's responses; Voyage provides embeddings for the
# knowledge-base RAG over the 15 brains. Both are server-only.
ANTHROPIC_API_KEY=your-anthropic-api-key
VOYAGE_API_KEY=your-voyage-api-key
# Optional model override (defaults to claude-sonnet-4-6):
# EARN_MODEL=claude-sonnet-4-6
# After deploying with the keys set, POST /api/knowledge/embed once (as an
# admin) to embed the 15 brain seeds into knowledge_chunks.
