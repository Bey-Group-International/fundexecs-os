# FundExecs OS — environment variables
# Copy to .env.local and fill in. Never commit real secrets.

# Supabase (client-safe)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase (server-only — bypasses RLS; keep secret)
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic (server-only) — powers the AI Agent Copilot. Without it, the
# copilot falls back to a deterministic plan so the app still runs.
ANTHROPIC_API_KEY=
# Optional — override the Claude model. Defaults to claude-haiku-4-5-20251001
# (cheap). Set to claude-sonnet-4-6 or claude-opus-4-8 to upgrade quality.
CLAUDE_MODEL=
# Optional — opt into web-search enrichment for AI Sourcing. When set to 1/true,
# the Source hub's "Source targets" searches the web for real, currently-
# operating firms (with a source link) instead of mandate-derived archetypes.
# Requires the web_search server tool to be enabled on the Anthropic account.
SOURCE_WEB_SEARCH=

# Integration channels (server-only, all OPTIONAL). The dispatch layer
# (lib/integrations) and the Unified Inbox follow a mock-or-real discipline:
# with none of these set, every channel prepares a draft/placeholder action
# instead of calling out, so the gate -> dispatch -> Outbox loop is fully
# observable. Setting a var only flips isConfigured()/the Settings "Connected"
# state — real OAuth token-exchange/refresh plumbing for these providers has
# not landed yet (only Gmail, via GMAIL_ACCESS_TOKEN through lib/email.ts, and
# Calendly, via CALENDLY_API_TOKEN below, actually call an external API today).
# Any one var per channel marks it configured.
GMAIL_ACCESS_TOKEN=
GOOGLE_OAUTH_CLIENT_ID=
DOCUSIGN_ACCESS_TOKEN=
DOCUSIGN_INTEGRATION_KEY=
SLACK_BOT_TOKEN=
CALENDLY_API_TOKEN=
GOOGLE_CALENDAR_ACCESS_TOKEN=
ZOOM_CLIENT_ID=
ZOOM_ACCOUNT_ID=
GOOGLE_MEET_ACCESS_TOKEN=
# AI Sourcing people/company lookup (lib/integrations/providers/apollo.ts) —
# live when set, ingest-only (no dispatch/write path).
APOLLO_API_KEY=
# Finance ingest channels (lib/integrations/adapters/finance.ts) — planned:
# marks the channel "configured" in Settings, but dispatch is still a
# placeholder until real Xero/Jax API plumbing lands.
XERO_ACCESS_TOKEN=
XERO_CLIENT_ID=
JAX_ACCESS_TOKEN=
JAX_API_KEY=

# Secret vault (server-only) — encryption key for the Settings → Secret vault,
# where orgs store third-party credentials for FundExecs to use on their behalf.
# Any sufficiently random string works (a 32-byte value is derived from it via
# SHA-256). Without it, the vault UI is disabled. Issued FundExecs API keys
# (Settings → API keys) do NOT need this — their secrets are hashed, not
# encrypted, and require SUPABASE_SERVICE_ROLE_KEY for verification.
FUNDEXECS_VAULT_KEY=
# Optional salt/pepper (server-only) for issued FundExecs API keys. Secret keys
# are stored as a scrypt digest over this value, so a leaked database is useless
# without it. Keep it stable — rotating it invalidates every issued secret key.
FUNDEXECS_API_KEY_PEPPER=

# Stripe (payments) — powers checkout for plans, credit packs, and gifts via
# hosted Stripe Checkout. With STRIPE_SECRET_KEY set, purchases go through real
# Checkout and are fulfilled on return; without it, the Wallet/Gift Earn flows
# fall back to mock mode (no charge) so the app still runs end-to-end.
STRIPE_SECRET_KEY=
# Publishable key — documented for client-side Stripe.js. The hosted-Checkout
# redirect flow doesn't need it, so it's optional.
STRIPE_PUBLISHABLE_KEY=
# Optional — when set, /api/stripe/webhook verifies and processes events as a
# second, redirect-independent fulfillment path (and a home for recurring
# subscription top-ups). Fulfillment works without it via the success redirect.
STRIPE_WEBHOOK_SECRET=

# Cron (server-only) — shared secret guarding /api/cron, which sweeps due
# scheduled automations. Vercel Cron sends it as `Authorization: Bearer <value>`.
CRON_SECRET=

# Brain ingest (server-only) — optional shared secret for the scripted/CI path of
# /api/brains/ingest. When set, callers can authenticate with
# `Authorization: Bearer <value>` instead of a logged-in org-writer session.
BRAIN_INGEST_SECRET=

# App — canonical site URL used for metadata, OG/Twitter cards, robots &
# sitemap. Set per-environment (localhost, Vercel preview, production).
# Falls back to https://fundexecs.com when unset.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Virtual Office WebSocket server (client-safe) — Railway deployment.
# Set this in Railway's "virtual-office-next" service environment variables
# (or the service that hosts Next.js) to point at the "virtual-office-server"
# Railway service public URL. Example:
#   NEXT_PUBLIC_WS_URL=wss://virtual-office-server.up.railway.app
# Falls back to ws://localhost:4000 when unset (local dev).
NEXT_PUBLIC_WS_URL=

# Virtual Office TURN/STUN relay (client-safe) — required for WebRTC behind NAT.
# Point at a coturn instance or a managed TURN provider (e.g. Twilio).
# Without these, peers on the same LAN connect fine; cross-network calls may fail.
NEXT_PUBLIC_TURN_URL=
NEXT_PUBLIC_TURN_USERNAME=
NEXT_PUBLIC_TURN_CREDENTIAL=

# Email delivery — Resend (server-only, OPTIONAL).
# When set, data-room share invites, document-ready notices, and fund updates are
# delivered via Resend. Falls back to Gmail (GMAIL_ACCESS_TOKEN) if set, then
# silent in-app mode when neither is configured.
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Inbound webhooks (server-only, OPTIONAL) — deploy-wide fallback signing
# secrets for app/api/webhooks/{resend,calendly}?org=<orgId>. Multi-tenant
# installs store these per-org in the Settings vault (RESEND_WEBHOOK_SECRET /
# CALENDLY_WEBHOOK_SECRET) instead; with neither set the webhook route fails
# closed (401) and nothing is ingested.
RESEND_WEBHOOK_SECRET=
CALENDLY_WEBHOOK_SECRET=

# DocuSign (server-only) — required for the subscription-agreement signing flow.
# DOCUSIGN_ACCESS_TOKEN — JWT/OAuth bearer token from DocuSign.
# DOCUSIGN_ACCOUNT_ID   — your DocuSign account UUID.
# DOCUSIGN_BASE_URL     — optional override (default: https://na4.docusign.net).
DOCUSIGN_ACCOUNT_ID=
DOCUSIGN_BASE_URL=
