# Supabase — copy this file to .env.local and fill in real values.
# Find these in your Supabase project: Settings → API.

# Safe to expose to the browser (used by the client + SSR clients).
# This must be the SAME host the app actually talks to. In production this is the
# Supabase CUSTOM DOMAIN https://auth.fundexecs.com (the bare https://<ref>.supabase.co
# URL also works, but the deployed app uses the custom domain). Google's OAuth
# callback is <this host>/auth/v1/callback, so the Authorized redirect URI in
# Google Cloud MUST match whatever is set here.
NEXT_PUBLIC_SUPABASE_URL=https://auth.fundexecs.com
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Canonical public origin of the app — auth (OAuth + email) always redirects
# back here regardless of which host initiated the flow. No trailing slash.
# Use the canonical production host www.fundexecs.com (the apex fundexecs.com
# 308-redirects to it); keeping auth on one host avoids losing the PKCE cookie
# across the apex→www redirect.
NEXT_PUBLIC_SITE_URL=https://www.fundexecs.com

# Server-only. NEVER expose this to the browser or commit it.
# Used for privileged server actions / admin tasks (ingestion writes via
# lib/supabase/admin.ts bypass RLS, so this key must stay server-side).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Integrations (relationship intelligence / warm connections) ---
# See docs/google-oauth-setup.md for full setup (OAuth apps + redirect URIs).
# The Integrations page is config-driven: a provider only shows "Connect" once
# its prerequisites below are present; otherwise it renders "Coming soon".
#
# Gmail + Google Calendar: ride the user's Supabase Google sign-in. Enable the
# Google provider in Supabase Auth and request these scopes (already requested
# at /login) so POST /api/integrations/{gmail|google_calendar}/sync works:
#   https://www.googleapis.com/auth/calendar.readonly
#   https://www.googleapis.com/auth/gmail.metadata
# Google Drive / Docs / Slides additionally use:
#   https://www.googleapis.com/auth/drive.readonly  (already requested at sign-in)
# That scope is "sensitive", so Google requires OAuth-app verification before the
# consent screen succeeds for non-test users. The cards are activated (they show
# "Connect"); connecting works for verified apps and for test users meanwhile.
#
# Google Meet: no env var — Meet calls are read from Google Calendar events that
# carry a Meet link, reusing the calendar.readonly scope above.
#
# Slack — OAuth app; redirect URI https://www.fundexecs.com/api/integrations/slack/callback
SLACK_CLIENT_ID=your-slack-client-id
SLACK_CLIENT_SECRET=your-slack-client-secret
# Optional (defaults to: im:read im:history users:read users:read.email)
# SLACK_USER_SCOPES=im:read im:history users:read users:read.email
#
# Calendly — OAuth app (PKCE); redirect URI https://www.fundexecs.com/api/integrations/calendly/callback
CALENDLY_CLIENT_ID=your-calendly-client-id
CALENDLY_CLIENT_SECRET=your-calendly-client-secret
# Optional (defaults to: users:read scheduled_events:read)
# CALENDLY_SCOPES=users:read scheduled_events:read
#
# Zoom — OAuth app (Zoom Marketplace, User-managed/General app); redirect URL
# https://www.fundexecs.com/api/integrations/zoom/callback
ZOOM_CLIENT_ID=your-zoom-client-id
ZOOM_CLIENT_SECRET=your-zoom-client-secret
# Optional (defaults to: user:read:user meeting:read:list_meetings meeting:read:list_registrants)
# ZOOM_SCOPES=user:read:user meeting:read:list_meetings meeting:read:list_registrants
#
# Google (optional) — only needed for background token refresh outside the
# Supabase session; users can otherwise reconnect to mint a fresh token.
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret
#
# Apollo — no env var; the API key is entered in the Integrations UI and stored
# server-side in private.integration_secrets.

# --- AI Copilot ("Earn") ---
# Claude powers Earn's responses; Voyage provides embeddings for the
# knowledge-base RAG over the 15 brains. Both are server-only.
ANTHROPIC_API_KEY=your-anthropic-api-key
VOYAGE_API_KEY=your-voyage-api-key
# Model tiering (all optional — see lib/ai/models.ts). Earn's interactive chat
# runs on the `chat` tier; deep, non-interactive judgment (diligence synthesis)
# on `reasoning`; high-volume parallel work (diligence analysts) on `fast`:
# EARN_MODEL=claude-sonnet-4-6              # chat tier (interactive)
# EARN_REASONING_MODEL=claude-opus-4-8     # reasoning tier (deep analysis)
# EARN_FAST_MODEL=claude-haiku-4-5-20251001 # fast tier (parallel lanes)
# Earn auto-escalates a clearly analytical chat turn from `chat` (Sonnet) to
# `reasoning` (Opus) for deeper thinking. Default ON; set to 0 to pin every
# turn to Sonnet:
# EARN_AUTO_REASONING=0                     # disable on-demand reasoning escalation
# Cost guardrail: bound the retrieved brain context injected per turn so input
# tokens (and spend) stay flat as the knowledge base grows. Chars, not tokens:
# EARN_RAG_CHUNK_MAX=700                     # max chars kept per retrieved chunk
# EARN_RAG_CONTEXT_MAX=4000                  # max chars of combined RAG context
# After deploying with the keys set, POST /api/knowledge/embed once (as an
# admin) to embed the 15 brain seeds into knowledge_chunks.

# --- Observability (Sentry) ---
# ALL OPTIONAL. The app builds and runs cleanly with NONE of these set — Sentry
# init is DSN-gated and source-map upload is skipped without an auth token.
#
# Set the DSN to turn on error reporting (client + server + edge). It is the
# only var needed at runtime to start capturing.
# NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
#
# Org/project + a CI-only auth token enable source-map upload at BUILD time so
# stack traces are readable. Leave the token unset for local/CI builds without
# Sentry — the build still passes. The token is server/CI-only; never expose it.
# SENTRY_ORG=your-sentry-org
# SENTRY_PROJECT=your-sentry-project
# SENTRY_AUTH_TOKEN=your-sentry-auth-token
#
# Optional tuning (all have safe defaults):
# NEXT_PUBLIC_SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.1
# NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
# NEXT_PUBLIC_SENTRY_REPLAY_SAMPLE_RATE=0
# NEXT_PUBLIC_SENTRY_REPLAY_ON_ERROR_SAMPLE_RATE=0

# --- Test data provisioning (local/admin only; never the real prod password) ---
# Used by scripts/provision-test-users.cjs to create/refresh the 5 test users.
# TEST_USER_PASSWORD=choose-a-throwaway-password

# --- e2e (Playwright) authed tests — ALL OPTIONAL ---
# The Playwright suite is green with none of these set: the authed specs
# (settings/admin gate, diligence surface, wallet, auth happy-path) self-skip
# when these + real Supabase env are absent. Set them (real Supabase URL/anon
# key + a seeded user) to exercise the authed critical paths in CI/locally.
# E2E_TEST_EMAIL=seeded-test-user@example.com
# E2E_TEST_PASSWORD=the-seeded-users-password

# --- Transactional email (OPTIONAL — Resend) ---
# Powers gift-credit emails and beta-invite magic-link delivery via lib/email/send.ts.
# Without a Resend key, gift emails degrade to a copyable link; beta invites first
# fall back to Supabase OTP email (if the Supabase project has email/SMTP), then to
# a copyable link. EMAIL_FROM applies to the Resend sender only.
#   RESEND_API_KEY: a Resend API key (https://resend.com).
#   EMAIL_FROM: the From header; must be a verified Resend sender/domain.
# RESEND_API_KEY=re_xxxxxxxx
# EMAIL_FROM=FundExecs OS <beta@fundexecs.com>

# --- Intelligence flywheel (scheduled sourcing & matching) ---
# Shared secret for the /api/cron/intelligence route. Vercel Cron sends it as
# `Authorization: Bearer $CRON_SECRET`; the route refuses to run without it.
CRON_SECRET=your-long-random-cron-secret

# SEC EDGAR requires a descriptive User-Agent with contact info on every
# request. Used by the Form D ingestion source (lib/integrations/edgar.ts).
EDGAR_USER_AGENT=FundExecs OS (ops@yourdomain.com)

# --- In-app calls (OPTIONAL — LiveKit, P4) ---
# Powers the Relationship Inbox in-app call rooms. Without these, calling is
# simply off: start/join return `not_configured` and the UI prompts setup —
# nothing else breaks. Tokens are minted server-side (lib/inbox/livekit.ts);
# never expose the API secret to the client.
#   LIVEKIT_API_KEY / LIVEKIT_API_SECRET: from your LiveKit project.
#   LIVEKIT_URL: the wss:// server URL the client connects to.
# LIVEKIT_API_KEY=APIxxxxxxxx
# LIVEKIT_API_SECRET=your-livekit-api-secret
# LIVEKIT_URL=wss://your-project.livekit.cloud
