PORT=4000
REDIS_URL=redis://localhost:6379

# REQUIRED — room authorization resolves every join against the caller's org
# memberships (organization_members via PostgREST). Rooms are org-namespaced
# server-side ("org:<orgId>:office-main"), so no seat exists outside the
# caller's own org. Without these the gateway fails closed and rejects all
# connections with 403.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# REQUIRED — the gateway verifies every WebSocket auth token's HS256 signature
# against this secret (Supabase → Project Settings → API → JWT Secret). Without
# it the gateway fails closed and rejects all connections; it must NOT be
# omitted, or forged tokens would grant anyone a seat in any meeting room.
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# mediasoup RTC port range — must be allowed through Railway's firewall.
# Go to: Railway service → Settings → Networking → expose UDP 40000-49999.
# Defaults work as-is; only change if you need a narrower range.
RTC_MIN_PORT=40000
RTC_MAX_PORT=49999
